
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is the owner of the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Secure all subcollections under a user's ID path
    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if isOwner(userId);
    }
    
    // User profile document itself
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // System-wide alerts (read-only for all logged users)
    match /system_alerts/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Temporarily allow writes for admin UI until custom claims are implemented
    }
    
    // Maintenance mode (read-only for all logged users)
    match /system_maintenance/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Token stock
    match /tokens/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // General fallback for development (ensure logged in)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
